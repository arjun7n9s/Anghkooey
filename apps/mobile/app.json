{
  "expo": {
    "name": "Anghkooey",
    "slug": "anghkooey",
    "version": "0.1.1",
    "orientation": "portrait",
    "scheme": "anghkooey",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FE3C00"
    },
    "ios": {
      "supportsTablet": false,
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan box QR codes and locate boxes",
        "NSMicrophoneUsageDescription": "Log box contents by voice"
      }
    },
    "android": {
      "package": "com.anghkooey.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FE3C00"
      },
      "permissions": [
        "INTERNET",
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Anghkooey to scan your box QR codes"
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a3960cfb-f35d-4326-9c01-a580f6f8693c"
      }
    },
    "owner": "arjun7n9s"
  }
}
